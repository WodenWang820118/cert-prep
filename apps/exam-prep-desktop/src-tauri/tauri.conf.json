{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Exam Prep",
  "version": "0.1.0",
  "identifier": "dev.certprep.exam-prep",
  "build": {
    "beforeDevCommand": "pnpm nx serve exam-prep",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "pnpm nx build exam-prep",
    "frontendDist": "../../../dist/apps/exam-prep/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Exam Prep",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["resources"]
  }
}
