{
  "name": "exam-prep-backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/exam-prep-backend/src",
  "tags": ["scope:exam", "type:backend"],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run uvicorn exam_prep_backend.app:create_app --factory --host 127.0.0.1 --port 8765"
      }
    },
    "test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "outputs": ["{workspaceRoot}/coverage/apps/exam-prep-backend"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run pytest"
      }
    },
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run ruff check ."
      }
    },
    "python-version-check": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run python -c \"import sys; print(sys.version); assert sys.version_info[:2] == (3, 13)\""
      }
    },
    "ocr-setup-cpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv sync --extra ocr-cpu --reinstall-package paddlepaddle && uv run --extra ocr-cpu python scripts/ocr_diagnostics.py --provider paddle --device cpu --strict-lane cpu --fail-on-error"
      }
    },
    "ocr-setup-gpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv sync --extra ocr-gpu --reinstall-package paddlepaddle-gpu && uv run --extra ocr-gpu python scripts/ocr_diagnostics.py --provider paddle --device gpu:0 --strict-lane gpu --fail-on-error"
      }
    },
    "ocr-setup-gpu-capable": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv sync --extra ocr-gpu --reinstall-package paddlepaddle-gpu && uv run --extra ocr-gpu python scripts/ocr_diagnostics.py --provider paddle --device auto --fail-on-error"
      }
    },
    "ocr-health": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run python scripts/ocr_diagnostics.py --provider paddle"
      }
    },
    "ocr-benchmark-cpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv sync --extra ocr-cpu --reinstall-package paddlepaddle && uv run --extra ocr-cpu python scripts/benchmark_ocr.py --device cpu --output .benchmarks/ocr-cpu-page3.json"
      }
    },
    "ocr-benchmark-gpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv sync --extra ocr-gpu --reinstall-package paddlepaddle-gpu && uv run --extra ocr-gpu python scripts/benchmark_ocr.py --device gpu:0 --output .benchmarks/ocr-gpu-page3.json"
      }
    },
    "build-sidecar": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run python scripts/build_sidecar.py --lane lite"
      }
    },
    "build-sidecar-cpu": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["ocr-setup-cpu"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run --extra ocr-cpu python scripts/build_sidecar.py --lane cpu"
      }
    },
    "build-sidecar-gpu": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["ocr-setup-gpu-capable"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run --extra ocr-gpu python scripts/build_sidecar.py --lane gpu"
      }
    },
    "build-ocr-runtime-gpu": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["ocr-setup-gpu-capable"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist/ocr-runtime"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run --extra ocr-gpu python scripts/build_ocr_runtime.py --lane gpu --target x86_64-pc-windows-msvc"
      }
    },
    "generate-openapi-client": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "outputs": ["{workspaceRoot}/apps/exam-prep/src/app/api/exam-prep-api.generated.ts"],
      "options": {
        "cwd": "apps/exam-prep-backend",
        "command": "uv run python scripts/generate_openapi_client.py --output ../../apps/exam-prep/src/app/api/exam-prep-api.generated.ts"
      }
    }
  }
}
