{
  "name": "cert-prep-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cert-prep-desktop/src-tauri/src",
  "tags": ["scope:cert", "type:desktop"],
  "implicitDependencies": ["cert-prep", "cert-prep-backend"],
  "targets": {
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-desktop",
        "command": "eslint . --ignore-pattern src-tauri/target/**"
      }
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["prepare-runtime-resources-dev"],
      "options": {
        "env": { "CERT_PREP_ALLOW_LOCAL_OCR_RUNTIME_URL": "true" },
        "command": "pnpm exec tauri dev --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "prepare-runtime-resources"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build-windowsml": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "prepare-runtime-resources"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --target x86_64-pc-windows-msvc --ci --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build-windowsml-dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "prepare-runtime-resources-dev"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --target x86_64-pc-windows-msvc --ci --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "local-candidate-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml-dev"],
      "outputs": ["{workspaceRoot}/tmp/local-alpha-candidate"],
      "options": {
        "command": "node tools/release/local-candidate.ts --workspace-root . --output-root tmp/local-alpha-candidate"
      }
    },
    "local-install-acceptance-nsis": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/local-install-acceptance"
      ],
      "options": {
        "command": "node tmp/local-alpha-candidate/harness/tools/release/local-install-acceptance.ts --workspace-root . --candidate-root tmp/local-alpha-candidate --output-root tmp/cert-prep-desktop/local-install-acceptance"
      }
    },
    "prepare-runtime-resources": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": [
        "cert-prep-backend:build-backend-runtime",
        "cert-prep-backend:build-ocr-runtime-windowsml"
      ],
      "outputs": ["{projectRoot}/src-tauri/generated-resources"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/prepare-runtime-resources.mts --mode release"
      }
    },
    "prepare-runtime-resources-dev": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": [
        "cert-prep-backend:build-backend-runtime",
        "cert-prep-backend:build-ocr-runtime-windowsml"
      ],
      "outputs": ["{projectRoot}/src-tauri/generated-resources"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/prepare-runtime-resources.mts --mode dev"
      }
    },
    "package-qa": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": ["{workspaceRoot}/tmp/cert-prep-desktop/package-qa"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/package-qa.mts"
      }
    },
    "process-residue-audit": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/process-residue-audit"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/process-residue-audit.mts"
      }
    },
    "packaged-flow-smoke": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": ["{workspaceRoot}/tmp/cert-prep-desktop/packaged-flow-smoke"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts"
      }
    },
    "packaged-flow-smoke-dev": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml-dev"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-flow-smoke-dev"
      ],
      "options": {
        "env": { "CERT_PREP_ALLOW_LOCAL_OCR_RUNTIME_URL": "true" },
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --out-root tmp/cert-prep-desktop/packaged-flow-smoke-dev"
      }
    },
    "packaged-document-cancellation-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-document-cancellation"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-document-cancellation.mts"
      }
    },
    "packaged-remaining-resilience-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-remaining-resilience"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-remaining-resilience-windowsml.mts"
      }
    },
    "local-resilience-evidence-verify": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-resilience/local-evidence-verifier.mts"
      }
    },
    "packaged-streaming-baseline-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-baseline"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --ocr-provider windowsml --ocr-page-workers 1 --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete"
      }
    },
    "packaged-streaming-production-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-production"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --production-summary --allow-ocr-chunk-variance --ocr-provider windowsml --ocr-page-workers 1 --llm-provider ollama --llm-model qwen3.5:4b --llm-fallback-models qwen3.5:2b --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete --verify-streaming-practice-ready"
      }
    },
    "packaged-streaming-production-recorded-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-production-recorded"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --production-summary --allow-ocr-chunk-variance --ocr-provider windowsml --ocr-page-workers 1 --llm-provider ollama --llm-model qwen3.5:4b --llm-fallback-models qwen3.5:2b --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete --verify-streaming-practice-ready --record-video --out-root tmp/cert-prep-desktop/packaged-streaming-production-recorded"
      }
    },
    "typecheck-scripts": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/tsconfig.scripts.json",
        "{projectRoot}/scripts/tsconfig.json"
      ],
      "options": {
        "command": "pnpm exec tsc -p tsconfig.scripts.json"
      }
    },
    "package-qa-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck-scripts"],
      "inputs": ["default"],
      "options": {
        "command": "node --import ./apps/cert-prep-desktop/scripts/package-qa/canonical-test-temp.mts --test apps/cert-prep-desktop/scripts/prepare-runtime-resources.test.mts apps/cert-prep-desktop/scripts/package-qa/artifacts.test.mts apps/cert-prep-desktop/scripts/package-qa/canonical-test-temp.test.mts apps/cert-prep-desktop/scripts/process-lifecycle/processes.test.mts apps/cert-prep-desktop/scripts/process-residue-audit.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/args.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/document-cancellation.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/document-runner.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/evidence-contract.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/local-evidence-verifier.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/ollama-isolation.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/operation-cancellation.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/owned-process-evidence.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/remaining-options.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/resilience-gates.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/resilience-runner.test.mts apps/cert-prep-desktop/scripts/packaged-resilience/session-restart.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/app-lifecycle.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/args.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/generation-readiness.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/ocr-completion.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/resource-sampling.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/runtime-install-flow.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/streaming-baseline-report.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/streaming-evidence.test.mts"
      }
    },
    "release-tool-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/tools/release/**",
        "{workspaceRoot}/.github/workflows/release-alpha.yml"
      ],
      "options": {
        "commands": [
          "node --test tools/release/*.test.ts",
          "uv run --project apps/cert-prep-backend python -m unittest discover -s tools/release -p test_*.py",
          "uv run --project apps/cert-prep-backend ruff check tools/release/collect-python-licenses.py tools/release/collect-runtime-payloads.py tools/release/test_collect_python_licenses.py tools/release/test_collect_runtime_payloads.py"
        ],
        "parallel": false
      }
    },
    "cargo-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "cargo test --manifest-path apps/cert-prep-desktop/src-tauri/Cargo.toml"
      }
    }
  }
}
