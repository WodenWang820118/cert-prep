{
  "name": "cert-prep-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cert-prep-desktop/src-tauri/src",
  "tags": ["scope:cert", "type:desktop"],
  "implicitDependencies": ["cert-prep", "cert-prep-backend"],
  "targets": {
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-desktop",
        "command": "eslint . --ignore-pattern src-tauri/target/**"
      }
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["prepare-runtime-resources-dev"],
      "options": {
        "env": { "CERT_PREP_ALLOW_LOCAL_OCR_RUNTIME_URL": "true" },
        "command": "pnpm exec tauri dev --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "prepare-runtime-resources"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build-windowsml": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "prepare-runtime-resources"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --target x86_64-pc-windows-msvc --ci --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build-windowsml-dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "prepare-runtime-resources-dev"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --target x86_64-pc-windows-msvc --ci --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "prepare-runtime-resources": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": [
        "cert-prep-backend:build-backend-runtime",
        "cert-prep-backend:build-ocr-runtime-windowsml"
      ],
      "outputs": ["{projectRoot}/src-tauri/generated-resources"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/prepare-runtime-resources.mts --mode release"
      }
    },
    "prepare-runtime-resources-dev": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": [
        "cert-prep-backend:build-backend-runtime",
        "cert-prep-backend:build-ocr-runtime-windowsml"
      ],
      "outputs": ["{projectRoot}/src-tauri/generated-resources"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/prepare-runtime-resources.mts --mode dev"
      }
    },
    "package-qa": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": ["{workspaceRoot}/tmp/cert-prep-desktop/package-qa"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/package-qa.mts"
      }
    },
    "process-residue-audit": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/process-residue-audit"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/process-residue-audit.mts"
      }
    },
    "packaged-flow-smoke": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": ["{workspaceRoot}/tmp/cert-prep-desktop/packaged-flow-smoke"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts"
      }
    },
    "packaged-flow-smoke-dev": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml-dev"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-flow-smoke-dev"
      ],
      "options": {
        "env": { "CERT_PREP_ALLOW_LOCAL_OCR_RUNTIME_URL": "true" },
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --out-root tmp/cert-prep-desktop/packaged-flow-smoke-dev"
      }
    },
    "packaged-streaming-baseline-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-baseline"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --ocr-provider windowsml --ocr-page-workers 1 --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete"
      }
    },
    "packaged-streaming-production-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-production"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --production-summary --allow-ocr-chunk-variance --ocr-provider windowsml --ocr-page-workers 1 --llm-provider auto --llm-model qwen3.5:4b --llm-fallback-models qwen3.5:2b --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete --verify-streaming-practice-ready"
      }
    },
    "packaged-streaming-production-recorded-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-production-recorded"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --production-summary --allow-ocr-chunk-variance --ocr-provider windowsml --ocr-page-workers 1 --llm-provider auto --llm-model qwen3.5:4b --llm-fallback-models qwen3.5:2b --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete --verify-streaming-practice-ready --record-video --out-root tmp/cert-prep-desktop/packaged-streaming-production-recorded"
      }
    },
    "typecheck-scripts": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/tsconfig.scripts.json",
        "{projectRoot}/scripts/tsconfig.json"
      ],
      "options": {
        "command": "pnpm exec tsc -p tsconfig.scripts.json"
      }
    },
    "package-qa-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck-scripts"],
      "inputs": ["default"],
      "options": {
        "command": "node --test apps/cert-prep-desktop/scripts/prepare-runtime-resources.test.mts apps/cert-prep-desktop/scripts/package-qa/artifacts.test.mts apps/cert-prep-desktop/scripts/process-lifecycle/processes.test.mts apps/cert-prep-desktop/scripts/process-residue-audit.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/app-lifecycle.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/args.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/generation-readiness.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/ocr-completion.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/owned-fastflow-process-lifecycle.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/resource-sampling.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/streaming-baseline-report.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/streaming-evidence.test.mts"
      }
    },
    "cargo-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "cargo test --manifest-path apps/cert-prep-desktop/src-tauri/Cargo.toml"
      }
    }
  }
}
