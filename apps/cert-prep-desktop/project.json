{
  "name": "cert-prep-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cert-prep-desktop/src-tauri/src",
  "tags": ["scope:cert", "type:desktop"],
  "implicitDependencies": ["cert-prep", "cert-prep-backend"],
  "targets": {
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-desktop",
        "command": "eslint . --ignore-pattern src-tauri/target/** --ignore-pattern src-tauri/binaries/**"
      }
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tauri dev --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep:build", "sync-backend-runtime-manifest"],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "build-windowsml": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "cert-prep:build",
        "sync-backend-runtime-manifest",
        "sync-windowsml-runtime-manifest"
      ],
      "outputs": ["{projectRoot}/src-tauri/target"],
      "options": {
        "command": "pnpm exec tauri build --target x86_64-pc-windows-msvc --ci --config apps/cert-prep-desktop/src-tauri/tauri.conf.json"
      }
    },
    "sync-sidecar": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep-backend:build-sidecar"],
      "outputs": ["{projectRoot}/src-tauri/binaries"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/sync-sidecar.mts"
      }
    },
    "sync-sidecar-gpu": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep-backend:build-sidecar-gpu"],
      "outputs": ["{projectRoot}/src-tauri/binaries"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/sync-sidecar.mts --target x86_64-pc-windows-msvc"
      }
    },
    "sync-runtime-manifest": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep-backend:build-ocr-runtime-gpu"],
      "outputs": [
        "{projectRoot}/src-tauri/resources/ocr-runtime-manifest.json"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/sync-runtime-manifest.mts"
      }
    },
    "sync-windowsml-runtime-manifest": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep-backend:build-ocr-runtime-windowsml"],
      "outputs": [
        "{projectRoot}/src-tauri/resources/windowsml-ocr-runtime-manifest.json"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/sync-windowsml-runtime-manifest.mts"
      }
    },
    "sync-backend-runtime-manifest": {
      "executor": "nx:run-commands",
      "dependsOn": ["cert-prep-backend:build-backend-runtime"],
      "outputs": [
        "{projectRoot}/src-tauri/resources/backend-runtime-manifest.json"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/sync-backend-runtime-manifest.mts"
      }
    },
    "package-qa": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": ["{workspaceRoot}/tmp/cert-prep-desktop/package-qa"],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/package-qa.mts"
      }
    },
    "packaged-flow-smoke": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-flow-smoke"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts"
      }
    },
    "packaged-streaming-baseline": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-baseline"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --ocr-page-workers 1 --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete"
      }
    },
    "packaged-streaming-baseline-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-baseline"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --ocr-provider windowsml --ocr-page-workers 1 --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete"
      }
    },
    "packaged-streaming-production-windowsml": {
      "cache": false,
      "executor": "nx:run-commands",
      "dependsOn": ["build-windowsml"],
      "outputs": [
        "{workspaceRoot}/tmp/cert-prep-desktop/packaged-streaming-production"
      ],
      "options": {
        "command": "node apps/cert-prep-desktop/scripts/packaged-flow-smoke.mts --production-summary --allow-ocr-chunk-variance --ocr-provider windowsml --ocr-page-workers 1 --ollama-fallback-models qwen3.5:2b --streaming-draft-page-limit 1 --streaming-draft-workers 1 --wait-for-streaming-complete --verify-streaming-practice-ready"
      }
    },
    "typecheck-scripts": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{workspaceRoot}/tsconfig.scripts.json",
        "{projectRoot}/scripts/tsconfig.json"
      ],
      "options": {
        "command": "pnpm exec tsc -p tsconfig.scripts.json"
      }
    },
    "package-qa-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck-scripts"],
      "inputs": ["default"],
      "options": {
        "command": "node --test apps/cert-prep-desktop/scripts/package-qa/artifacts.test.mts apps/cert-prep-desktop/scripts/package-qa/health-env.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/args.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/processes.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/resource-sampling.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/streaming-baseline-report.test.mts apps/cert-prep-desktop/scripts/packaged-flow-smoke/streaming-evidence.test.mts"
      }
    },
    "cargo-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "cargo test --manifest-path apps/cert-prep-desktop/src-tauri/Cargo.toml"
      }
    }
  }
}
