{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cert Prep",
  "version": "0.1.0",
  "identifier": "dev.certprep.cert-prep",
  "build": {
    "beforeDevCommand": "pnpm nx serve cert-prep",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "pnpm nx build cert-prep",
    "frontendDist": "../../../dist/apps/cert-prep/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cert Prep",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["resources"]
  }
}
