{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cert Prep",
  "version": "0.1.0-alpha.1",
  "identifier": "dev.certprep.cert-prep",
  "build": {
    "beforeDevCommand": "pnpm nx serve cert-prep",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "pnpm nx build cert-prep",
    "frontendDist": "../../../dist/apps/cert-prep/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cert Prep",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "version": "0.1.0.1"
      }
    },
    "resources": {
      "generated-resources/*": "resources/",
      "../../../LICENSE": "legal/LICENSE",
      "../../../PRIVACY.md": "legal/PRIVACY.md",
      "../../../CHANGELOG.md": "legal/CHANGELOG.md",
      "../../../THIRD_PARTY_NOTICES.md": "legal/THIRD_PARTY_NOTICES.md"
    }
  }
}
