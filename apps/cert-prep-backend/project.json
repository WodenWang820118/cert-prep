{
  "name": "cert-prep-backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cert-prep-backend/src",
  "tags": ["scope:cert", "type:backend"],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run uvicorn cert_prep_backend.api.app:create_app --factory --host 127.0.0.1 --port 8765"
      }
    },
    "test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "outputs": ["{workspaceRoot}/coverage/apps/cert-prep-backend"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run pytest"
      }
    },
    "streaming-cli-test": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run pytest tests/test_documents_streaming.py tests/test_ocr_igpu_probe.py tests/test_fastflowlm_provider.py -k \"streaming or fastflowlm or igpu\""
      }
    },
    "lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run ruff check ."
      }
    },
    "python-version-check": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run python -c \"import sys; print(sys.version); assert sys.version_info[:2] in {(3, 12), (3, 13)}\""
      }
    },
    "ocr-setup-cpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv sync --extra ocr-cpu --reinstall-package paddlepaddle && uv run --extra ocr-cpu python scripts/ocr_diagnostics.py --provider paddle --device cpu --strict-lane cpu --fail-on-error"
      }
    },
    "ocr-setup-gpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv sync --extra ocr-gpu --reinstall-package paddlepaddle-gpu && uv run --extra ocr-gpu python scripts/ocr_diagnostics.py --provider paddle --device gpu:0 --strict-lane gpu --fail-on-error"
      }
    },
    "ocr-setup-gpu-capable": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv sync --extra ocr-gpu --reinstall-package paddlepaddle-gpu && uv run --extra ocr-gpu python scripts/ocr_diagnostics.py --provider paddle --device auto --fail-on-error"
      }
    },
    "ocr-health": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run python scripts/ocr_diagnostics.py --provider paddle"
      }
    },
    "ocr-benchmark-cpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv sync --extra ocr-cpu --reinstall-package paddlepaddle && uv run --extra ocr-cpu python scripts/benchmark_ocr.py --device cpu --output .benchmarks/ocr-cpu-page3.json"
      }
    },
    "ocr-benchmark-gpu": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv sync --extra ocr-gpu --reinstall-package paddlepaddle-gpu && uv run --extra ocr-gpu python scripts/benchmark_ocr.py --device gpu:0 --output .benchmarks/ocr-gpu-page3.json"
      }
    },
    "ocr-igpu-probe": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --extra ocr-gpu python scripts/ocr_igpu_probe.py"
      }
    },
    "ocr-windowsml-probe": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --exact --reinstall-package onnxruntime-windowsml --python 3.12 --extra ocr-windowsml python -m cert_prep_ocr_windowsml.tools.windowsml.ocr_windowsml_probe"
      }
    },
    "ocr-windowsml-prepare-models": {
      "cache": false,
      "parallelism": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "env": { "UV_LINK_MODE": "copy" },
        "command": "uv run --isolated --python 3.12 --extra ocr-windowsml python -m cert_prep_ocr_windowsml.tools.windowsml.ocr_windowsml_prepare_models"
      }
    },
    "ocr-windowsml-prepare-models-docker": {
      "cache": false,
      "parallelism": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --exact --reinstall-package onnxruntime-windowsml --python 3.12 --extra ocr-windowsml python -m cert_prep_ocr_windowsml.tools.windowsml.ocr_windowsml_prepare_models --converter docker --force-conversion --fail-if-not-ready"
      }
    },
    "ocr-windowsml-session-smoke": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --exact --reinstall-package onnxruntime-windowsml --python 3.12 --extra ocr-windowsml python -m cert_prep_ocr_windowsml.tools.windowsml.ocr_windowsml_smoke"
      }
    },
    "ocr-windowsml-inference-smoke": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --exact --reinstall-package onnxruntime-windowsml --python 3.12 --extra ocr-windowsml python -m cert_prep_ocr_windowsml.tools.windowsml.ocr_windowsml_inference_smoke"
      }
    },
    "ocr-windowsml-benchmark": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --exact --reinstall-package onnxruntime-windowsml --python 3.12 --extra ocr-windowsml python -m cert_prep_ocr_windowsml.tools.windowsml.ocr_windowsml_benchmark"
      }
    },
    "reasoning-bakeoff": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run python scripts/reasoning_bakeoff.py"
      }
    },
    "reasoning-memory": {
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.benchmarks"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run python scripts/reasoning_memory.py"
      }
    },
    "build-backend-runtime": {
      "cache": true,
      "parallelism": false,
      "executor": "nx:run-commands",
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist/backend-runtime"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "env": { "UV_LINK_MODE": "copy" },
        "command": "uv run --isolated --python 3.12 python scripts/build_backend_runtime.py --target x86_64-pc-windows-msvc --version 0.1.0-alpha.1"
      }
    },
    "build-ocr-runtime-gpu": {
      "cache": true,
      "parallelism": false,
      "executor": "nx:run-commands",
      "dependsOn": ["ocr-setup-gpu-capable"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist/ocr-runtime"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run --extra ocr-gpu python scripts/build_ocr_runtime.py --lane gpu --target x86_64-pc-windows-msvc"
      }
    },
    "build-ocr-runtime-windowsml": {
      "cache": true,
      "parallelism": false,
      "executor": "nx:run-commands",
      "dependsOn": ["ocr-windowsml-prepare-models"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist/ocr-windowsml-runtime"],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "env": { "UV_LINK_MODE": "copy" },
        "command": "uv run --isolated --python 3.12 --extra ocr-windowsml python scripts/build_ocr_runtime.py --lane windowsml --target x86_64-pc-windows-msvc --version 0.1.0-alpha.1"
      }
    },
    "generate-openapi-client": {
      "cache": true,
      "parallelism": false,
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "outputs": [
        "{workspaceRoot}/libs/cert-prep-api/src/lib/cert-prep-api.generated.ts"
      ],
      "options": {
        "cwd": "apps/cert-prep-backend",
        "command": "uv run python scripts/generate_openapi_client.py --output ../../libs/cert-prep-api/src/lib/cert-prep-api.generated.ts"
      }
    }
  },
  "implicitDependencies": ["cert-prep-ocr-windowsml"]
}
